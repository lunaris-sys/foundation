\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Knowledge Graph core schema. Nodes represent entities; edges represent relationships. \texttt  {Event} nodes are the lowest-level entries, created directly from the event pipeline. \texttt  {UserAction} nodes are derived abstractions built from clusters of raw events. A \texttt  {File} can belong to multiple \texttt  {Project} nodes simultaneously; membership is an edge, not a property of the file.}}{28}{figure.caption.45}\protected@file@percent }
\newlabel{fig:kg-schema}{{5}{28}{Knowledge Graph core schema. Nodes represent entities; edges represent relationships. \texttt {Event} nodes are the lowest-level entries, created directly from the event pipeline. \texttt {UserAction} nodes are derived abstractions built from clusters of raw events. A \texttt {File} can belong to multiple \texttt {Project} nodes simultaneously; membership is an edge, not a property of the file}{figure.caption.45}{}}
